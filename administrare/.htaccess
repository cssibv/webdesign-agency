Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^private(/|$) - [F]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "no-referrer"
  Header set X-Robots-Tag "noindex, nofollow"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://challenges.cloudflare.com; form-action 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'"
</IfModule>

<FilesMatch "\.(sql|md|example\.php)$">
  Require all denied
</FilesMatch>

# Strat extra (opțional): generează private/.htpasswd, apoi decomentează.
# AuthType Basic
# AuthName "Zona privata"
# AuthUserFile "/cale/absoluta/catre/administrare/private/.htpasswd"
# Require valid-user
